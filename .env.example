# Copy to .env.local and fill in real values from your Firebase project console.
# Get these from Firebase Console → Project Settings → Your apps → Web app config.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# The seed super-admin email used by the bootstrap seed script.
# This account becomes the first super_admin on its first sign-in.
# (Used only by scripts/seed.js — NOT read by the running app.)
# AMS_SEED_SUPER_ADMIN=zahalyanxcho@gmail.com
